{
  "manifest_version": 3,
  "name": "Duplicador de Produto Inteligente",
  "version": "1.1.0",
  "description": "Automatiza o preenchimento de campos repetidos na janela 'Duplicar produto' do painel da Nuvemshop e permite envio de marca d'água via clique.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.nuvemshop.com.br/*",
        "*://*.lojavirtualnuvem.com.br/*",
        "*://*.tiendanube.com/*",
        "*://*.mitiendanube.com/*",
        "https://*.onrender.com/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
